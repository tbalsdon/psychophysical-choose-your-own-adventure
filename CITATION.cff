title: "Psychophysics & Decision-Making: interactive tutorials"
message: "If you use these tutorials, please cite them using the metadata below."
type: dataset
authors:
  - given-names: Tarryn
    family-names: Balsdon
    # orcid: "https://orcid.org/0000-0000-0000-0000"   # <- add your ORCID here
